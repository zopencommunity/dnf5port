 class MemStream {
 public:
     MemStream() {
+#ifdef __MVS__
+        stream = memstream_open(&buf, &len);
+#else
         stream = open_memstream(&buf, &len);
+#endif
         if (!stream) {
             throw std::system_error(errno, std::system_category(), "open_memstream");
         }
     }
 
     ~MemStream() {
+#ifdef __MVS__
+        memstream_finish(stream, &buf, &len);
+#endif
         CPPUNIT_ASSERT_EQUAL(fclose(stream), 0);
         free(buf);
     }
@@ -57,6 +64,14 @@ public:
 
     std::string_view get_string_view() noexcept {
         CPPUNIT_ASSERT_EQUAL(fflush(stream), 0);
+#ifdef __MVS__
+        if (buf) {
+            free(buf);
+            buf = NULL;
+            len = 0;
+        }
+        memstream_finish(stream, &buf, &len);
+#endif
         return std::string_view(buf, len);
     }
 
